# ============================================================
# Taekwondo SaaS - Environment Variables (TEMPLATE)
# Copy this file to .env and fill in your values
# ============================================================

# Database (MySQL)
DATABASE_URL="mysql://root:your_password@localhost:3306/taekwondo_saas"

# JWT
JWT_SECRET="CHANGE_ME_to_a_long_random_secret_key_min_32_chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development

# CORS (Frontend URL)
CORS_ORIGIN="http://localhost:5173"
